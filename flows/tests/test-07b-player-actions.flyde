imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: give-item
      inputConfig: {}
      nodeId: GiveItem
      config:
        アイテムID:
          type: string
          value: minecraft:apple
        個数:
          type: number
          value: 1
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: assert-076
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: true
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-076
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 500
      id: add-level
      inputConfig: {}
      nodeId: AddPlayerLevel
      config:
        レベル:
          type: number
          value: 1
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 500
