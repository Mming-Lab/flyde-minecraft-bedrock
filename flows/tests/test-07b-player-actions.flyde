  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: give-item
        pinId: トリガー
    - from:
        insId: give-item
        pinId: 完了
      to:
        insId: assert-076
        pinId: 実際値
    - from:
        insId: assert-076
        pinId: 完了
      to:
        insId: add-level
        pinId: トリガー
    - from:
        insId: add-level
        pinId: 完了
      to:
        insId: assert-080
        pinId: 実際値
    - from:
        insId: assert-080
        pinId: 完了
      to:
        insId: set-title
        pinId: トリガー
    - from:
        insId: set-title
        pinId: 完了
      to:
        insId: assert-084
        pinId: 実際値
    - from:
        insId: assert-084
        pinId: 完了
      to:
