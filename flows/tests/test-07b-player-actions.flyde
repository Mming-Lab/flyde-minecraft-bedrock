        pinId: トリガー
    - from:
        insId: clear-title
        pinId: 完了
      to:
        insId: assert-086
        pinId: 実際値
    - from:
        insId: assert-086
        pinId: 完了
      to:
        insId: disconnect
        pinId: トリガー
  id: TestPlayerActions
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: プレイヤーアクションノードテスト（TC-076/080/084/085/086）チャット送信1回で自動実行
