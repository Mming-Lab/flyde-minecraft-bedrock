imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: add-obj
      inputConfig: {}
      nodeId: AddScoreboardObjective
      config:
        目標ID:
          type: string
          value: mcflowtest
        表示名:
          type: string
          value: テスト目標
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 96.99563598632812
        y: 517.2204284667969
      id: score-set
      inputConfig: {}
      nodeId: ScoreOperation
      config:
        操作:
          type: select
          value: set
        目標ID:
          type: string
          value: mcflowtest
        値:
          type: number
          value: 42
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
        プレイヤー名:
          type: dynamic
          value: "{{プレイヤー名}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 650
        y: 500
      id: assert-sb02
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: number
          value: 42
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-SB02
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 700
      id: get-score
      inputConfig: {}
      nodeId: GetScore
      config:
        目標ID:
          type: string
          value: mcflowtest
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
        プレイヤー名:
          type: dynamic
          value: "{{プレイヤー名}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 650
        y: 700
      id: assert-sb03
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: number
          value: 42
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-SB03
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 900
      id: score-add
      inputConfig: {}
      nodeId: ScoreOperation
      config:
        操作:
          type: select
          value: add
        目標ID:
          type: string
          value: mcflowtest
        値:
          type: number
          value: 8
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
        プレイヤー名:
          type: dynamic
          value: "{{プレイヤー名}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 650
        y: 900
      id: assert-sb04
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: number
          value: 50
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-SB04
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 1100
      id: remove-obj
      inputConfig: {}
      nodeId: RemoveScoreboardObjective
      config:
        目標ID:
          type: string
          value: mcflowtest
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 650
        y: 1100
      id: assert-sb05
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: true
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-SB05
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 889.9547621471024
        y: 1114.8552587629474
      id: MinecraftDisconnect-yelfo5vg
      inputConfig: {}
      nodeId: MinecraftDisconnect
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: add-obj
        pinId: トリガー
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: score-set
        pinId: プレイヤー名
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: get-score
        pinId: プレイヤー名
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: score-add
        pinId: プレイヤー名
    - from:
        insId: add-obj
        pinId: 目標
      to:
        insId: score-set
        pinId: トリガー
    - from:
        insId: score-set
        pinId: 新スコア
      to:
        insId: assert-sb02
        pinId: 実際値
    - from:
        insId: assert-sb02
        pinId: 完了
      to:
        insId: get-score
        pinId: トリガー
    - from:
        insId: get-score
        pinId: スコア
      to:
        insId: assert-sb03
        pinId: 実際値
    - from:
        insId: assert-sb03
        pinId: 完了
      to:
        insId: score-add
        pinId: トリガー
    - from:
        insId: score-add
        pinId: 新スコア
      to:
        insId: assert-sb04
        pinId: 実際値
    - from:
        insId: assert-sb04
        pinId: 完了
      to:
        insId: remove-obj
        pinId: トリガー
    - from:
        insId: remove-obj
        pinId: 結果
      to:
        insId: assert-sb05
        pinId: 実際値
    - from:
        insId: assert-sb05
        pinId: 完了
      to:
        insId: MinecraftDisconnect-yelfo5vg
        pinId: トリガー
  id: TestScoreboard
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: スコアボードノードテスト（チャット送信1回で自動実行、送信者名をプレイヤー名に使用）
