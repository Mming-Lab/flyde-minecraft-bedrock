imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: add-obj
      inputConfig: {}
      nodeId: AddScoreboardObjective
      config:
        目標ID:
          type: string
          value: mcflowtest2
        表示名:
          type: string
          value: テスト目標2
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: get-from-obj-151
      inputConfig: {}
      nodeId: GetFromScoreboardObjective
      config:
        目標:
          type: dynamic
          value: "{{目標}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 650
        y: 300
      id: assert-151
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: string
          value: mcflowtest2
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-151
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 50
        y: 500
      id: get-obj
      inputConfig: {}
      nodeId: GetScoreboardObjective
      config:
        目標ID:
          type: string
          value: mcflowtest2
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 500
      id: get-from-obj-153
      inputConfig: {}
      nodeId: GetFromScoreboardObjective
      config:
        目標:
          type: dynamic
          value: "{{目標}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 650
        y: 500
      id: assert-153
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: string
          value: mcflowtest2
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-153
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 50
        y: 700
      id: get-objectives
      inputConfig: {}
      nodeId: GetScoreboardObjectives
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 700
      id: score-set
      inputConfig: {}
      nodeId: ScoreOperation
      config:
        操作:
          type: select
          value: set
        目標ID:
          type: string
          value: mcflowtest2
        値:
          type: number
          value: 99
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
        プレイヤー名:
          type: dynamic
          value: "{{プレイヤー名}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 50
        y: 900
      id: get-scores
      inputConfig: {}
      nodeId: GetScores
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
        プレイヤー名:
          type: dynamic
          value: "{{プレイヤー名}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 900
      id: remove-obj
      inputConfig: {}
      nodeId: RemoveScoreboardObjective
      config:
        目標ID:
          type: string
          value: mcflowtest2
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 1100
      id: disconnect
      inputConfig: {}
      nodeId: MinecraftDisconnect
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: add-obj
        pinId: トリガー
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: score-set
        pinId: プレイヤー名
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: get-scores
        pinId: プレイヤー名
    - from:
        insId: add-obj
        pinId: 目標
      to:
        insId: get-from-obj-151
        pinId: 目標
    - from:
        insId: get-from-obj-151
        pinId: 目標ID
      to:
        insId: assert-151
        pinId: 実際値
    - from:
        insId: assert-151
        pinId: 完了
      to:
        insId: get-obj
        pinId: トリガー
    - from:
        insId: get-obj
        pinId: 目標
      to:
        insId: get-from-obj-153
        pinId: 目標
    - from:
        insId: get-from-obj-153
        pinId: 目標ID
      to:
        insId: assert-153
        pinId: 実際値
    - from:
        insId: assert-153
        pinId: 完了
      to:
        insId: get-objectives
        pinId: トリガー
    - from:
        insId: get-objectives
        pinId: 目標一覧
      to:
        insId: score-set
        pinId: トリガー
    - from:
        insId: score-set
        pinId: 新スコア
      to:
        insId: get-scores
        pinId: トリガー
    - from:
        insId: get-scores
        pinId: スコア一覧
      to:
        insId: remove-obj
        pinId: トリガー
    - from:
        insId: remove-obj
        pinId: 結果
      to:
        insId: disconnect
        pinId: トリガー
  id: TestScoreboard2
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: スコアボードクエリノードテスト（TC-151/153 Assert、TC-152/155 implicit）チャット送信1回で自動実行
